# Monorepo environment reference.
# For shell-driven commands such as `pnpm test:e2e` or `pnpm test:smoke`, export the
# variables you need into the current shell. Example:
#   set -a; source .env; set +a
#
# Python services started from their own service directory can also read a local `.env`
# file if the service supports it.

# ------------------------------------------------------------------------------
# Frontend / H5
# ------------------------------------------------------------------------------
VITE_PLATFORM_API_BASE_URL=http://127.0.0.1:8000
VITE_MESSAGE_GATEWAY_WS_URL=ws://127.0.0.1:8010/ws
VITE_AI_SERVICE_BASE_URL=http://127.0.0.1:8020

# ------------------------------------------------------------------------------
# Flutter
# ------------------------------------------------------------------------------
APP_PLATFORM_API_BASE_URL=http://127.0.0.1:8000
APP_MESSAGE_GATEWAY_WS_URL=ws://127.0.0.1:8010/ws

# ------------------------------------------------------------------------------
# platform-api
# ------------------------------------------------------------------------------
APP_ENV=development
APP_NAME=platform-api
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/platform
APP_JWT_SECRET=dev-secret-for-platform-api-please-change
APP_JWT_ALGORITHM=HS256
APP_CORS_ORIGINS=["*"]
APP_DEFAULT_ADMIN_USERNAME=admin
APP_DEFAULT_ADMIN_PASSWORD=admin123
APP_BOOTSTRAP_DEFAULT_ADMIN=true
APP_BOOTSTRAP_SAMPLE_DATA=true
APP_REDIS_URL=redis://127.0.0.1:6379/0
APP_OPENSEARCH_URL=http://127.0.0.1:9200
APP_MINIO_ENDPOINT=127.0.0.1:9000

# ------------------------------------------------------------------------------
# message-gateway
# ------------------------------------------------------------------------------
APP_GATEWAY_HOST=0.0.0.0
APP_GATEWAY_PORT=8010

# ------------------------------------------------------------------------------
# ai-service
# ------------------------------------------------------------------------------
APP_AI_HOST=0.0.0.0
APP_AI_PORT=8020
AI_SERVICE_DEFAULT_PROVIDER=openai_like
AI_SERVICE_OPENAI_LIKE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_SERVICE_OPENAI_LIKE_API_KEY=
AI_SERVICE_OPENAI_LIKE_MODELS=qwen-plus,qwen-max,deepseek-v3
AI_SERVICE_VLLM_BASE_URL=http://127.0.0.1:8100/v1
AI_SERVICE_VLLM_MODELS=mixtral,llama-3.1,qwen2.5
AI_SERVICE_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_SERVICE_OLLAMA_MODELS=llama3.2,mistral,qwen2.5
AI_SERVICE_OPENSEARCH_URL=http://127.0.0.1:9200
AI_SERVICE_OPENSEARCH_INDEX=knowledge_chunks
AI_SERVICE_OPENSEARCH_USERNAME=
AI_SERVICE_OPENSEARCH_PASSWORD=

# Compatibility aliases accepted by ai-service.
QWEN_API_KEY=
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Docker / infra defaults
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=platform
POSTGRES_PORT=5432
REDIS_PORT=6379
PLATFORM_DATA_ROOT=../../data
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin123!Admin123!
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_METRICS_PORT=9600
